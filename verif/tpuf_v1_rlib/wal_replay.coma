use int.Int

type t_Uuid

type t_Vec_f32_Global

type t_WalEntry = { seq_no: UInt64.t; id: t_Uuid; values: t_Vec_f32_Global }

predicate inv_Uuid (_1: t_Uuid)

predicate inv_WalEntry (_1: t_WalEntry)

axiom inv_axiom [@rewrite]: forall x: t_WalEntry [inv_WalEntry x]. inv_WalEntry x = inv_Uuid x.id

predicate invariant_ref_WalEntry [@inline:trivial] (self: t_WalEntry) = [%#sinvariant] inv_WalEntry self

meta "rewrite_def" predicate invariant_ref_WalEntry

predicate inv_ref_WalEntry [@inline:trivial] (_1: t_WalEntry) = invariant_ref_WalEntry _1

meta "rewrite_def" predicate inv_ref_WalEntry

predicate invariant_Seq_WalEntry [@inline:trivial] (self: Seq.seq t_WalEntry) =
  [%#sseq] forall i: int. 0 <= i /\ i < Seq.length self -> inv_ref_WalEntry (Seq.get self i)

meta "rewrite_def" predicate invariant_Seq_WalEntry

predicate inv_Seq_WalEntry [@inline:trivial] (_1: Seq.seq t_WalEntry) = invariant_Seq_WalEntry _1

meta "rewrite_def" predicate inv_Seq_WalEntry

predicate invariant_slice_WalEntry (self: Slice64.slice t_WalEntry) = [%#sslice'1] inv_Seq_WalEntry (Slice64.view self)

predicate inv_slice_WalEntry [@inline:trivial] (_1: Slice64.slice t_WalEntry) = invariant_slice_WalEntry _1

meta "rewrite_def" predicate inv_slice_WalEntry

predicate invariant_ref_slice_WalEntry [@inline:trivial] (self: Slice64.slice t_WalEntry) =
  [%#sinvariant] inv_slice_WalEntry self

meta "rewrite_def" predicate invariant_ref_slice_WalEntry

predicate inv_ref_slice_WalEntry [@inline:trivial] (_1: Slice64.slice t_WalEntry) = invariant_ref_slice_WalEntry _1

meta "rewrite_def" predicate inv_ref_slice_WalEntry

let rec len_WalEntry (self_: Slice64.slice t_WalEntry) (return (x: UInt64.t)) =
