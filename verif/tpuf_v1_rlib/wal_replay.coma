        | s8 = {[@expl:index in bounds] [%#slib'7] _25} s9
        | s9 = Slice64Ops.get [%#slib'8] <t_WalEntry> {log} {_22} (fun (r: t_WalEntry) -> [ &_21 <- r.seq_no ] s10)
        | s10 = [ &_16 <- UInt64.le _17 _21 ] s11
