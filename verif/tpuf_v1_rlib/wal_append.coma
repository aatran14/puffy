let rec wal_append [#"/Users/andyt/v1_practice/src/lib.rs" 125 0 125 59] (log: MutBorrow.t t_Vec_WalEntry_Global)
  (entry: t_WalEntry) (return (x: ())) =
  {[@stop_split] [@expl:wal_append requires] ([@stop_split] [@expl:wal_append 'log' type invariant] [%#slib'0] inv_refmut_Vec_WalEntry_Global log)
  /\ ([@stop_split] [@expl:wal_append 'entry' type invariant] [%#slib'1] inv_WalEntry entry)
  /\ ([@stop_split] [@expl:wal_append requires] [%#slib'2] Seq.length (view_Vec_WalEntry_Global log.current) = 0
  \/ UInt64.gt entry.seq_no (Seq.get (view_Vec_WalEntry_Global log.current) (Seq.length (view_Vec_WalEntry_Global log.current)
  - 1)).seq_no)}
  (! bb0
  [ bb0 = s0
    [ s0 = MutBorrow.borrow_final <t_Vec_WalEntry_Global> {log.current} {MutBorrow.get_id log}
        (fun (_bor: MutBorrow.t t_Vec_WalEntry_Global) ->
          [ &_7 <- _bor ] -{inv_Vec_WalEntry_Global _bor.final}-
          [ &log <- { log with current = _bor.final } ] s1)
      [ _ck -> (! {[@expl:type invariant] inv_Vec_WalEntry_Global log.current} any) ]
    | s1 = push_WalEntry [%#slib] {_7} {entry} (fun (_x: ()) -> [ &_6 <- _x ] s2)
    | s2 = s3 [ _ck -> (! {[@expl:type invariant] inv_refmut_Vec_WalEntry_Global log} any) ]
    | s3 = -{resolve_refmut_Vec_WalEntry_Global log}- s4
    | s4 = return {_ret} ] ]
  [ & _ret: () = Any.any_l ()
  | & log: MutBorrow.t t_Vec_WalEntry_Global = log
  | & entry: t_WalEntry = entry
  | & _6: () = Any.any_l ()
  | & _7: MutBorrow.t t_Vec_WalEntry_Global = Any.any_l () ]) [ return (result: ()) -> (! return {result}) ]
